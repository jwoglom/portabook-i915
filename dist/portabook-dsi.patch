 	intel_dsi->pixel_format =
 		vbt_to_dsi_pixel_format(mipi_config->videomode_color_format);
 
+	/*
+	 * Diagnostic overrides for garbled internal DSI panels whose VBT
+	 * disagrees with the firmware GOP programming. Off (-1) by default.
+	 * See i915.dsi_pixel_format_override / i915.dsi_dual_link_override.
+	 */
+	if (display->params.dsi_pixel_format_override >= 0) {
+		static const enum mipi_dsi_pixel_format override_fmt[] = {
+			MIPI_DSI_FMT_RGB888,
+			MIPI_DSI_FMT_RGB666,
+			MIPI_DSI_FMT_RGB666_PACKED,
+			MIPI_DSI_FMT_RGB565,
+		};
+		int sel = display->params.dsi_pixel_format_override;
+
+		if ((size_t)sel < ARRAY_SIZE(override_fmt)) {
+			intel_dsi->pixel_format = override_fmt[sel];
+			drm_info(&dev_priv->drm,
+				 "DSI: overriding pixel format from VBT to %d (i915.dsi_pixel_format_override=%d)\n",
+				 intel_dsi->pixel_format, sel);
+		} else {
+			drm_warn(&dev_priv->drm,
+				 "DSI: ignoring out-of-range i915.dsi_pixel_format_override=%d\n",
+				 sel);
+		}
+	}
+
 	intel_dsi->dual_link = mipi_config->dual_link;
+
+	if (display->params.dsi_dual_link_override >= 0) {
+		intel_dsi->dual_link = display->params.dsi_dual_link_override;
+		drm_info(&dev_priv->drm,
+			 "DSI: overriding dual_link from VBT to %d (i915.dsi_dual_link_override)\n",
+			 intel_dsi->dual_link);
+	}
 	intel_dsi->pixel_overlap = mipi_config->pixel_overlap;
 	intel_dsi->operation_mode = mipi_config->is_cmd_mode;
 	intel_dsi->video_mode = mipi_config->video_transfer_mode;
