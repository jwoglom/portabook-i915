# Downloaded Ubuntu kernel source package (reproducible via `apt-get source`; ~475 MB)
linux-hwe-*.orig.tar.*
linux-hwe-*.diff.gz
linux-hwe-*.dsc
*.deb

# Extracted / prepared kernel source tree (~2.3 GB) and headers extract — both reproducible
linux-hwe-6.14-6.14.0/
hdr-extract/

# Compiled build outputs.
# dist/i915.ko.zst IS tracked (below) so `git clone` + install-on-portabook.sh works
# out of the box. The uncompressed i915.ko is redundant (the script uses the .zst),
# so it stays ignored to keep clones small.
*.ko
*.ko.zst
*.o
*.ko.zst.orig
!dist/i915.ko.zst

# Packaged bundle produced by `tar czf`
portabook-i915-fix.tar.gz

# Editor / OS cruft
*.swp
*~
.DS_Store
